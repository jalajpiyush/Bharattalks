{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile representation in Swiply",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "User email address"
        },
        "name": {
          "type": "string",
          "description": "User display name"
        },
        "country": {
          "type": "string",
          "description": "User location/country"
        },
        "avatar": {
          "type": "string",
          "description": "User selected emoji avatar icon"
        },
        "isPremium": {
          "type": "boolean",
          "description": "True if user is VIP / Premium"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user registered"
        }
      },
      "required": ["email", "name"]
    },
    "PaymentRecord": {
      "title": "PaymentRecord",
      "description": "Premium access subscription payments logged in Firestore",
      "type": "object",
      "properties": {
        "txnid": {
          "type": "string",
          "description": "PayU transaction ID"
        },
        "amount": {
          "type": "string",
          "description": "Payment amount in INR"
        },
        "firstname": {
          "type": "string",
          "description": "Payer billing first name"
        },
        "email": {
          "type": "string",
          "description": "Payer registered billing email"
        },
        "phone": {
          "type": "string",
          "description": "Payer mobile phone digits"
        },
        "plan": {
          "type": "string",
          "description": "Premium billing plan (monthly or yearly)"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Exact transaction registration timestamp"
        }
      },
      "required": ["txnid", "amount", "email"]
    },
    "UserReport": {
      "title": "UserReport",
      "description": "Safety report filed against a user",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique report ID"
        },
        "reporterEmail": {
          "type": "string",
          "description": "Email of the reporting user"
        },
        "reporterPeerId": {
          "type": "string",
          "description": "Peer ID of the reporting user"
        },
        "reportedPeerId": {
          "type": "string",
          "description": "Peer ID of the reported user"
        },
        "reportedName": {
          "type": "string",
          "description": "Display name of the reported user"
        },
        "reason": {
          "type": "string",
          "description": "Reason category of the report"
        },
        "comments": {
          "type": "string",
          "description": "Additional comments/feedback from the reporter"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Exact time the report was submitted"
        }
      },
      "required": ["id", "reporterPeerId", "reportedPeerId", "reason", "timestamp"]
    },
    "UserBlock": {
      "title": "UserBlock",
      "description": "Durable block registry preventing future match encounters",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique block ID"
        },
        "blockerEmail": {
          "type": "string",
          "description": "Email of the blocking user"
        },
        "blockerPeerId": {
          "type": "string",
          "description": "Peer ID of the blocking user"
        },
        "blockedPeerId": {
          "type": "string",
          "description": "Peer ID of the blocked user"
        },
        "blockedName": {
          "type": "string",
          "description": "Display name of the blocked user"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Exact time the block was submitted"
        }
      },
      "required": ["id", "blockerPeerId", "blockedPeerId", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Durable Firestore registry for Swiply users and their VIP premium subscriptions"
    },
    "/payments/{paymentId}": {
      "schema": "PaymentRecord",
      "description": "Durable ledger of PayU transactions"
    },
    "/reports/{reportId}": {
      "schema": "UserReport",
      "description": "Safety reports filed against users for inappropriate behavior"
    },
    "/blocks/{blockId}": {
      "schema": "UserBlock",
      "description": "Indicates user blocks to prevent future matchmaking and interactions"
    }
  }
}
